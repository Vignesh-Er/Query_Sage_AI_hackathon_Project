# QuerySage local-first environment configuration templates
# Backend Configuration
QUERYSAGE_DB_PATH=~/.querysage/querysage.db
QUERYSAGE_HOST=127.0.0.1
QUERYSAGE_PORT=8421

# AI Reasoning Configuration
# options: 'anthropic' or 'ollama'
QUERYSAGE_AI_PROVIDER=anthropic
QUERYSAGE_ANTHROPIC_API_KEY=your-api-key-here
QUERYSAGE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local LLM config (Ollama)
QUERYSAGE_OLLAMA_HOST=http://localhost:11434
QUERYSAGE_OLLAMA_MODEL=llama3

# Playwright rendering timeout in ms
QUERYSAGE_PLAYWRIGHT_TIMEOUT=30000
